Aggregation
	db.users.aggregate([{
	   $group:{
	      _id:"$address.city",
	      totalUsers:{$sum:1}}
	 }
	])
	
Computed fields
	db.users.aggregate([
	 {
	   $project:{
	      name:1,
	      fullAddress:{
		 $concat:[
		   "$address.street",
		   ", ",
		   "$address.city"
		 ]
	      }
	   }
	 }
	])
	
